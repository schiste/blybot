# Blybot configuration template (spec section 12).
#
# On Toolforge, copy to a 0600-permission file in the tool home directory
# and source it from run.sh. NEVER commit a filled-in copy.

# --- required -------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
WIKI_USERNAME=
WIKI_BOTPASSWORD=
# Talk page for /log entries (one section per entry)
LOG_TARGET_PAGE=
# Talk page holding DM discussions (one section per session)
DM_TARGET_BASE=
# WMF User-Agent policy: tool name, version, contact URL/email.
# Example: Blybot/0.1 (https://meta.wikimedia.org/wiki/User:Blybot; ops@example.org)
USER_AGENT=

# --- optional (defaults shown) ---------------------------------------------
#BOT_NAME=Blybot
#WIKI_API_URL=https://meta.wikimedia.org/w/api.php
#ALLOWED_GROUP_IDS=
#SESSION_TTL_MINUTES=45
#BURST_DEBOUNCE_SECONDS=8
#TIMESTAMP_GRANULARITY=date
# prompt (in-group deep-link welcome on joins) or off
#NEWCOMER_WELCOME=prompt
# immediate or author_only ("confirm" is reserved for the N1 flow, not yet implemented)
#CONSENT_MODE=immediate
#LOG_THROTTLE_PER_MINUTE=6
#BUG_THROTTLE_PER_HOUR=3
#WIKI_MAX_RETRIES=5
# Seconds before the /log command / the bot's replies are deleted (0 = keep)
#LOG_CLEANUP_SECONDS=5
#REPLY_CLEANUP_SECONDS=15
# --- self-service (v2): enables per-group configuration from Telegram ----
# Leaf appended to every /setpage base path (e.g. "Telegram logs" makes
# "/setpage WikiProject Foo" publish to "WikiProject Foo/Telegram logs").
# Empty disables self-service page targeting.
#WIKI_PAGE_SUFFIX=Telegram logs
# Fernet key enabling ToolsDB profiles + encrypted group tokens. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#PROFILE_ENCRYPTION_KEY=
#TOOLSDB_HOST=tools.db.svc.wikimedia.cloud
#TOOLSDB_NAME=
#TOOLSDB_CNF=~/replica.my.cnf
# Minutes between repository-event polls that feed the /rule notifications
#EVENTS_POLL_MINUTES=5

# Fine-grained PAT (Issues read/write on the repo only) enabling /bug reports
#GITHUB_TOKEN=
#GITHUB_REPO=schiste/blybot
# Shown in /help, e.g. "User:Schiste (meta.wikimedia.org/wiki/User:Schiste)"
#MAINTAINER=
#GROUP_GREETING_TEXT=
#WELCOME_TEXT=
